{
  "name": "playwright-api-automation-framework",
  "version": "1.0.0",
  "description": "Enterprise-grade API automation framework built with Playwright, TypeScript, and modern testing practices",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:parallel": "playwright test --workers=4",
    "test:serial": "playwright test --workers=1",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:trace": "playwright show-trace",
    "lint": "eslint src --max-warnings=0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "type-check": "tsc --noEmit",
    "build": "tsc",
    "clean": "rm -rf dist results",
    "prebuild": "npm run clean",
    "prepare": "npm run build"
  },
  "keywords": [
    "api-testing",
    "automation",
    "playwright",
    "typescript",
    "rest-api",
    "e2e-testing",
    "enterprise"
  ],
  "author": "SDET Team",
  "license": "MIT",
  "dependencies": {
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.43.1",
    "ajv": "^8.12.0",
    "dotenv": "^16.4.5",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "@typescript-eslint/parser": "^6.20.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
